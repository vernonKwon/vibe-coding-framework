# GitHub
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic (Claude Code) — 아래 중 하나만 선택
# 방법 1: API Key (토큰당 과금)
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# 방법 2: OAuth (Max 구독, 월정액)
# 호스트에서 `claude login` 실행 후 docker-compose.yml의 ~/.claude 마운트로 세션 공유
# 이 경우 ANTHROPIC_API_KEY는 설정하지 않는다

# Git
GIT_AUTHOR_NAME=refactor-agent
GIT_AUTHOR_EMAIL=refactor-agent@your-domain.com
GIT_COMMITTER_NAME=refactor-agent
GIT_COMMITTER_EMAIL=refactor-agent@your-domain.com
